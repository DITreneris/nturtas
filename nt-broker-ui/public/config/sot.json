  "libraryPrompts": [
    {
      "id": "skelbimas_nt",
      "title": "NT skelbimo šablonas",
      "desc": "Portalams ir socialiniams kanalams",
      "icon": "sparkles",
      "prompt": "Rolė: NT rinkos analitikas ir aukščiausio lygio NT brokeris (15m patirtis).\nGoal: Sukurti skelbimą pagal objekto duomenis – emocinis arba racionalus kampas.\nTone: premium\nINPUT: Objektas, lokacija, kaina, plotas/kambariai, privalumai, auditorija.\nREASONING: Analizuok objekto vertę, identifikuok auditorijos motyvaciją, suformuok stipriausią pardavimo kampą.\nOUTPUT: Hook, pagrindinis tekstas, 3-5 USP, emocinis argumentas, CTA.\nQUALITY: Tiksli lietuvių kalba, jokio salesy triukšmo, maksimalus įtraukimas."
    },
    {
      "id": "komunikacija_pirkėjas",
      "title": "Klientų komunikacija",
      "desc": "Atsakymai pirkėjams ir pardavėjams",
      "icon": "message-square",
      "prompt": "Rolė: NT brokerio asistentas. Parengti atsakymą klientui (pirkėjas/pardavėjas) pagal situaciją.\nSituacijos: domisi kaina, neatsako, follow-up po apžiūros, pasiūlymo teikimas.\nOUTPUT: Trumpas, profesionalus atsakymas – vertė, aiškumas, CTA (susitikimas/skambutis).\nTone: pagal kontekstą (premium/profesionalus/draugiškas). Tiksli lietuvių kalba."
    },
    {
      "id": "derybu_strategija",
      "title": "Derybų argumentacija",
      "desc": "Tikslas, kainos, kontekstas",
      "icon": "handshake",
      "prompt": "Rolė: NT derybų strategas. Suformuoti argumentaciją tikslui: ginti kainą / ieškoti kompromiso / uždaryti sandorį.\nINPUT: Pradinė kaina, siūloma kaina, rinkos kontekstas.\nOUTPUT: 3-5 stiprūs argumentai, atsakymai į tipinius prieštaravimus, aiškus siūlomas žingsnis. Tiksli lietuvių kalba, be agresijos."
    },
    {
      "id": "rinkos_analize",
      "title": "Rinkos analizė / turinys",
      "desc": "Ekspertinis turinys tema",
      "icon": "bar-chart-3",
      "prompt": "Rolė: NT rinkos analitikas. Sukurti ekspertinį turinį (apžvalga, įžvalgos) nurodyta tema.\nINPUT: Tema, turinio tipas (ekspertinis / apžvalga / prognozė).\nOUTPUT: Struktūruotas turinys – faktai, tendencijos, išvados. Tiksli lietuvių kalba, vertė skaitytojui, jokio tuščio marketingo."
    }
  ],
